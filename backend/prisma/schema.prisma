generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                        String                 @id @default(uuid())
  name                      String
  createdAt                 DateTime               @default(now()) @map("created_at")
  updatedAt                 DateTime               @updatedAt @map("updated_at")
  whatsappStrategy          String?                @default("RANDOM") @map("whatsapp_strategy")
  defaultWhatsappInstanceId String?                @map("default_whatsapp_instance_id")
  aiKnowledge               AIKnowledge?
  appointments              Appointment[]
  campaigns                 Campaign[]
  customers                 Customer[]
  Flow                      Flow[]
  googleCalendar            GoogleCalendar?
  invites                   Invite[]
  pipelineStages            PipelineStage[]
  serviceAdditionals        ServiceAdditional[]
  serviceCombos             ServiceCombo[]
  serviceZoneExceptions     ServiceZoneException[]
  serviceZones              ServiceZone[]
  services                  Service[]
  tags                      Tag[]
  users                     User[]
  whatsappInstances         WhatsAppInstance[]
  whatsappLinks             WhatsAppLink[]

  @@map("companies")
}

model Tag {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  name      String
  color     String?  @default("#8B5CF6")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("tags")
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  passwordHash   String?        @map("password_hash")
  name           String
  role           UserRole       @default(USER)
  companyId      String         @map("company_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  cargo          String?
  status         String         @default("ACTIVE")
  conversations  Conversation[]
  customerNotes  CustomerNote[]
  sentInvites    Invite[]       @relation("InviteSender")
  receivedInvite Invite?        @relation("InviteReceiver")
  permissions    Permission[]
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
  @@index([status])
  @@map("users")
}

model Customer {
  id              String         @id @default(uuid())
  companyId       String         @map("company_id")
  name            String
  phone           String
  email           String?
  tags            String[]       @default([])
  notes           String?
  profilePicUrl   String?        @map("profile_pic_url")
  isGroup         Boolean        @default(false) @map("is_group")
  pipelineStageId String?        @map("pipeline_stage_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  address         String?
  neighborhood    String?
  zoneId          String?        @map("zone_id")
  appointments    Appointment[]
  conversations   Conversation?
  customerNotes   CustomerNote[]
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])
  zone            ServiceZone?   @relation("CustomerZone", fields: [zoneId], references: [id])
  messages        Message[]

  @@unique([companyId, phone])
  @@index([companyId])
  @@index([phone])
  @@index([email])
  @@index([isGroup])
  @@index([pipelineStageId])
  @@index([zoneId])
  @@map("customers")
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  userId     String   @map("user_id")
  note       String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([userId])
  @@index([createdAt])
  @@map("customer_notes")
}

model WhatsAppInstance {
  id           String         @id @default(uuid())
  companyId    String         @map("company_id")
  instanceName String         @map("instance_name")
  displayName  String?        @map("display_name")
  apiKey       String?        @map("api_key")
  qrCode       String?        @map("qr_code")
  status       WhatsAppStatus @default(DISCONNECTED)
  phoneNumber  String?        @map("phone_number")
  connectedAt  DateTime?      @map("connected_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  messages     Message[]
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, instanceName])
  @@index([companyId])
  @@index([status])
  @@map("whatsapp_instances")
}

model Message {
  id                 String           @id @default(uuid())
  customerId         String           @map("customer_id")
  whatsappInstanceId String           @map("whatsapp_instance_id")
  direction          MessageDirection
  content            String
  timestamp          DateTime
  status             MessageStatus    @default(SENT)
  messageId          String?          @map("message_id")
  senderType         SenderType?      @default(HUMAN) @map("sender_type")
  feedback           MessageFeedback? @map("feedback")
  feedbackNote       String?          @map("feedback_note")
  mediaType          String?          @default("text") @map("media_type")
  mediaUrl           String?          @map("media_url")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  quotedContent      String?          @map("quoted_content")
  quotedMessageId    String?          @map("quoted_message_id")
  customer           Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  whatsappInstance   WhatsAppInstance @relation(fields: [whatsappInstanceId], references: [id], onDelete: Cascade)

  @@unique([whatsappInstanceId, messageId])
  @@index([customerId])
  @@index([whatsappInstanceId])
  @@index([timestamp])
  @@index([messageId])
  @@index([feedback])
  @@index([mediaType])
  @@map("messages")
}

model Conversation {
  id                        String               @id @default(uuid())
  customerId                String               @unique @map("customer_id")
  companyId                 String               @map("company_id")
  assignedToId              String?              @map("assigned_to_id")
  aiEnabled                 Boolean              @default(true) @map("ai_enabled")
  needsHelp                 Boolean              @default(false) @map("needs_help")
  appointmentState          Json?                @map("appointment_state")
  createdAt                 DateTime             @default(now()) @map("created_at")
  updatedAt                 DateTime             @updatedAt @map("updated_at")
  activeIntentScriptId      String?              @map("active_intent_script_id")
  intentScriptCollectedData Json?                @map("intent_script_collected_data")
  conversationExample       ConversationExample?
  assignedTo                User?                @relation(fields: [assignedToId], references: [id])
  customer                  Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([assignedToId])
  @@index([aiEnabled])
  @@index([needsHelp])
  @@map("conversations")
}

model AIKnowledge {
  id                   String    @id @default(uuid())
  companyId            String    @unique @map("company_id")
  companyName          String?   @map("company_name")
  companySegment       String?   @map("company_segment")
  companyDescription   String?   @map("company_description")
  companyInfo          String?   @map("company_info")
  aiObjective          String?   @map("ai_objective")
  aiPersonality        String?   @map("ai_personality")
  toneInstructions     String?   @map("tone_instructions")
  policies             String?
  workingHours         String?   @map("working_hours")
  paymentMethods       String?   @map("payment_methods")
  deliveryInfo         String?   @map("delivery_info")
  warrantyInfo         String?   @map("warranty_info")
  serviceArea          String?   @map("service_area")
  productsServices     String?   @map("products_services")
  products             Json?     @default("[]")
  negativeExamples     String?   @map("negative_examples")
  faq                  Json?     @default("[]")
  generatedContext     String?   @map("generated_context")
  contextGeneratedAt   DateTime? @map("context_generated_at")
  setupCompleted       Boolean   @default(false) @map("setup_completed")
  setupStep            Int       @default(0) @map("setup_step")
  provider             String?   @default("openai")
  model                String?
  temperature          Float?    @default(0.7)
  maxTokens            Int?      @default(500)
  autoReplyEnabled     Boolean   @default(true) @map("auto_reply_enabled")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  objectiveType        String?   @default("support") @map("objective_type")
  businessHoursEnd     Int?      @default(18) @map("business_hours_end")
  businessHoursStart   Int?      @default(9) @map("business_hours_start")
  aiClosingFocus       Boolean?  @default(false) @map("ai_closing_focus")
  aiCustomInstructions String?   @map("ai_custom_instructions")
  aiProactivity        String?   @default("medium") @map("ai_proactivity")
  aiTone               String?   @default("professional") @map("ai_tone")
  replyDelay           Int       @default(10) @map("reply_delay")
  intentScriptsConfig  Json?     @map("intent_scripts_config")
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("ai_knowledge")
}

model ConversationExample {
  id             String       @id @default(uuid())
  companyId      String       @map("company_id")
  conversationId String       @unique @map("conversation_id")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([conversationId])
  @@map("conversation_examples")
}

model Campaign {
  id              String         @id @default(uuid())
  companyId       String         @map("company_id")
  name            String
  messageTemplate String         @map("message_template")
  targetTags      String[]       @default([]) @map("target_tags")
  type            CampaignType
  status          CampaignStatus @default(DRAFT)
  scheduledAt     DateTime?      @map("scheduled_at")
  sentCount       Int            @default(0) @map("sent_count")
  failedCount     Int            @default(0) @map("failed_count")
  totalTarget     Int            @default(0) @map("total_target")
  startedAt       DateTime?      @map("started_at")
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  logs            CampaignLog[]
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([type])
  @@index([scheduledAt])
  @@map("campaigns")
}

model CampaignLog {
  id            String            @id @default(uuid())
  campaignId    String            @map("campaign_id")
  customerId    String            @map("customer_id")
  customerName  String            @map("customer_name")
  customerPhone String            @map("customer_phone")
  status        CampaignLogStatus @default(PENDING)
  message       String
  error         String?
  sentAt        DateTime?         @map("sent_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  campaign      Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([customerId])
  @@index([status])
  @@map("campaign_logs")
}

model PipelineStage {
  id          String     @id @default(uuid())
  companyId   String     @map("company_id")
  name        String
  description String?
  color       String     @default("#8B5CF6")
  order       Int
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  customers   Customer[]
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@index([order])
  @@map("pipeline_stages")
}

model GoogleCalendar {
  id           String   @id @default(uuid())
  companyId    String   @unique @map("company_id")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  tokenExpiry  DateTime @map("token_expiry")
  calendarId   String?  @map("calendar_id")
  email        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("google_calendars")
}

model Appointment {
  id            String            @id @default(uuid())
  companyId     String            @map("company_id")
  customerId    String            @map("customer_id")
  title         String
  description   String?
  type          AppointmentType   @default(VISIT)
  status        AppointmentStatus @default(SCHEDULED)
  startTime     DateTime          @map("start_time")
  endTime       DateTime          @map("end_time")
  duration      Int               @default(60)
  location      String?
  googleEventId String?           @map("google_event_id")
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([customerId])
  @@index([startTime])
  @@index([status])
  @@index([type])
  @@map("appointments")
}

model WhatsAppLink {
  id          String      @id @default(uuid())
  companyId   String      @map("company_id")
  name        String
  slug        String      @unique
  phoneNumber String      @map("phone_number")
  message     String?
  autoTag     String?     @map("auto_tag")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  clicks      LinkClick[]
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([slug])
  @@index([isActive])
  @@map("whatsapp_links")
}

model LinkClick {
  id          String       @id @default(uuid())
  linkId      String       @map("link_id")
  ipAddress   String?      @map("ip_address")
  userAgent   String?      @map("user_agent")
  referer     String?
  country     String?
  region      String?
  city        String?
  latitude    Float?
  longitude   Float?
  deviceType  String?      @map("device_type")
  browser     String?
  os          String?
  converted   Boolean      @default(false)
  convertedAt DateTime?    @map("converted_at")
  customerId  String?      @map("customer_id")
  clickedAt   DateTime     @default(now()) @map("clicked_at")
  link        WhatsAppLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([clickedAt])
  @@index([country])
  @@index([deviceType])
  @@index([converted])
  @@map("link_clicks")
}

model Invite {
  id          String       @id @default(uuid())
  companyId   String       @map("company_id")
  email       String
  name        String
  cargo       String?
  token       String       @unique
  status      InviteStatus @default(PENDING)
  invitedById String       @map("invited_by_id")
  userId      String?      @unique @map("user_id")
  expiresAt   DateTime     @map("expires_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy   User         @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  user        User?        @relation("InviteReceiver", fields: [userId], references: [id], onDelete: Cascade)
  permissions Permission[]

  @@index([companyId])
  @@index([email])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
  @@map("invites")
}

model Permission {
  id        String         @id @default(uuid())
  userId    String?        @map("user_id")
  inviteId  String?        @map("invite_id")
  page      PermissionPage
  canView   Boolean        @default(true) @map("can_view")
  canEdit   Boolean        @default(false) @map("can_edit")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  invite    Invite?        @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  user      User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, page])
  @@index([userId])
  @@index([inviteId])
  @@index([page])
  @@map("permissions")
}

model Service {
  id            String               @id @default(uuid())
  companyId     String               @map("company_id")
  name          String
  description   String?
  basePrice     Decimal              @map("base_price") @db.Decimal(10, 2)
  type          ServiceType          @default(SERVICE)
  category      String?
  isActive      Boolean              @default(true) @map("is_active")
  order         Int                  @default(0)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  duration      Int?                 @default(60)
  actionType    String?              @map("action_type")
  equipmentType String?              @map("equipment_type")
  comboItems    ServiceComboItem[]
  pricingTiers  ServicePricingTier[]
  variables     ServiceVariable[]
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@index([isActive])
  @@index([type])
  @@map("services")
}

model ServiceVariable {
  id          String                  @id @default(uuid())
  serviceId   String                  @map("service_id")
  name        String
  description String?
  isRequired  Boolean                 @default(true) @map("is_required")
  order       Int                     @default(0)
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  options     ServiceVariableOption[]
  service     Service                 @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_variables")
}

model ServiceVariableOption {
  id            String          @id @default(uuid())
  variableId    String          @map("variable_id")
  name          String
  priceModifier Decimal         @map("price_modifier") @db.Decimal(10, 2)
  order         Int             @default(0)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  variable      ServiceVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)

  @@index([variableId])
  @@map("service_variable_options")
}

model ServicePricingTier {
  id           String   @id @default(uuid())
  serviceId    String   @map("service_id")
  minQuantity  Int      @map("min_quantity")
  maxQuantity  Int?     @map("max_quantity")
  pricePerUnit Decimal  @map("price_per_unit") @db.Decimal(10, 2)
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  service      Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_pricing_tiers")
}

model ServiceZone {
  id            String          @id @default(uuid())
  companyId     String          @map("company_id")
  name          String
  description   String?
  pricingType   ZonePricingType @default(FIXED) @map("pricing_type")
  priceModifier Decimal         @default(0) @map("price_modifier") @db.Decimal(10, 2)
  neighborhoods String[]        @default([])
  isDefault     Boolean         @default(false) @map("is_default")
  requiresQuote Boolean         @default(false) @map("requires_quote")
  isActive      Boolean         @default(true) @map("is_active")
  order         Int             @default(0)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  customers     Customer[]      @relation("CustomerZone")
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@index([isDefault])
  @@index([isActive])
  @@map("service_zones")
}

model ServiceCombo {
  id          String             @id @default(uuid())
  companyId   String             @map("company_id")
  name        String
  description String?
  fixedPrice  Decimal            @map("fixed_price") @db.Decimal(10, 2)
  category    String?
  isActive    Boolean            @default(true) @map("is_active")
  order       Int                @default(0)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  items       ServiceComboItem[]
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@index([isActive])
  @@index([category])
  @@map("service_combos")
}

model ServiceComboItem {
  id        String       @id @default(uuid())
  comboId   String       @map("combo_id")
  serviceId String       @map("service_id")
  quantity  Int          @default(1)
  notes     String?
  order     Int          @default(0)
  combo     ServiceCombo @relation(fields: [comboId], references: [id], onDelete: Cascade)
  service   Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([comboId])
  @@index([serviceId])
  @@map("service_combo_items")
}

model ServiceAdditional {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  name                String
  description         String?
  price               Decimal  @db.Decimal(10, 2)
  appliesToCategories String[] @default([]) @map("applies_to_categories")
  isActive            Boolean  @default(true) @map("is_active")
  order               Int      @default(0)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@index([isActive])
  @@map("service_additionals")
}

model ServiceZoneException {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  zoneId        String   @map("zone_id")
  serviceId     String?  @map("service_id")
  category      String?
  minQuantity   Int?     @map("min_quantity")
  exceptionType String   @map("exception_type")
  customFee     Decimal? @map("custom_fee") @db.Decimal(10, 2)
  description   String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([zoneId])
  @@index([serviceId])
  @@index([category])
  @@map("service_zone_exceptions")
}

model Flow {
  id                 String          @id @default(uuid())
  companyId          String          @map("company_id")
  name               String
  description        String?
  triggerType        String          @default("webhook") @map("trigger_type")
  webhookSlug        String?         @unique @map("webhook_slug")
  lastWebhookPayload Json?           @map("last_webhook_payload")
  status             FlowStatus      @default(DRAFT)
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  autoTags           String[]        @default([]) @map("auto_tags")
  edges              FlowEdge[]
  executions         FlowExecution[]
  nodes              FlowNode[]
  company            Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@map("flows")
}

model FlowNode {
  id          String          @id
  flowId      String          @map("flow_id")
  type        String
  data        Json
  positionX   Float           @map("position_x")
  positionY   Float           @map("position_y")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  sourceEdges FlowEdge[]      @relation("SourceNode")
  targetEdges FlowEdge[]      @relation("TargetNode")
  executions  FlowExecution[] @relation("CurrentNode")
  flow        Flow            @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@map("flow_nodes")
}

model FlowEdge {
  id           String   @id
  flowId       String   @map("flow_id")
  sourceNodeId String   @map("source_node_id")
  sourceHandle String?  @map("source_handle")
  targetNodeId String   @map("target_node_id")
  targetHandle String?  @map("target_handle")
  createdAt    DateTime @default(now()) @map("created_at")
  flow         Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  sourceNode   FlowNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   FlowNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@map("flow_edges")
}

model FlowExecution {
  id                 String              @id @default(uuid())
  flowId             String              @map("flow_id")
  contactPhone       String              @map("contact_phone")
  currentNodeId      String?             @map("current_node_id")
  history            Json?               @default("[]")
  variables          Json?               @default("{}")
  status             FlowExecutionStatus @default(RUNNING)
  error              String?
  resumesAt          DateTime?           @map("resumes_at")
  startedAt          DateTime            @default(now()) @map("started_at")
  completedAt        DateTime?           @map("completed_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  whatsappInstanceId String?             @map("whatsapp_instance_id")
  currentNode        FlowNode?           @relation("CurrentNode", fields: [currentNodeId], references: [id])
  flow               Flow                @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([contactPhone])
  @@index([status])
  @@index([resumesAt])
  @@map("flow_executions")
}


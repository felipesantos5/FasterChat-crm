generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ai_knowledge {
  id                     String    @id
  company_id             String    @unique
  company_name           String?
  company_segment        String?
  company_description    String?
  company_info           String?
  ai_objective           String?
  ai_personality         String?
  tone_instructions      String?
  policies               String?
  working_hours          String?
  payment_methods        String?
  delivery_info          String?
  warranty_info          String?
  service_area           String?
  products_services      String?
  products               Json?     @default("[]")
  negative_examples      String?
  faq                    Json?     @default("[]")
  generated_context      String?
  context_generated_at   DateTime?
  setup_completed        Boolean   @default(false)
  setup_step             Int       @default(0)
  provider               String?   @default("openai")
  model                  String?
  temperature            Float?    @default(0.7)
  maxTokens              Int?      @default(500)
  auto_reply_enabled     Boolean   @default(true)
  created_at             DateTime  @default(now())
  updated_at             DateTime
  objective_type         String?   @default("support")
  business_hours_end     Int?      @default(18)
  business_hours_start   Int?      @default(9)
  ai_closing_focus       Boolean?  @default(false)
  ai_custom_instructions String?
  ai_proactivity         String?   @default("medium")
  ai_tone                String?   @default("professional")
  reply_delay            Int       @default(10)
  intent_scripts_config  Json?
  companies              companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model appointments {
  id              String            @id
  company_id      String
  customer_id     String
  title           String
  description     String?
  type            AppointmentType   @default(VISIT)
  status          AppointmentStatus @default(SCHEDULED)
  start_time      DateTime
  end_time        DateTime
  duration        Int               @default(60)
  location        String?
  google_event_id String?
  notes           String?
  created_at      DateTime          @default(now())
  updated_at      DateTime
  companies       companies         @relation(fields: [company_id], references: [id], onDelete: Cascade)
  customers       customers         @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([customer_id])
  @@index([start_time])
  @@index([status])
  @@index([type])
}

model campaign_logs {
  id             String            @id
  campaign_id    String
  customer_id    String
  customer_name  String
  customer_phone String
  status         CampaignLogStatus @default(PENDING)
  message        String
  error          String?
  sent_at        DateTime?
  created_at     DateTime          @default(now())
  campaigns      campaigns         @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@index([campaign_id])
  @@index([customer_id])
  @@index([status])
}

model campaigns {
  id               String          @id
  company_id       String
  name             String
  message_template String
  target_tags      String[]        @default([])
  type             CampaignType
  status           CampaignStatus  @default(DRAFT)
  scheduled_at     DateTime?
  sent_count       Int             @default(0)
  failed_count     Int             @default(0)
  total_target     Int             @default(0)
  started_at       DateTime?
  completed_at     DateTime?
  created_at       DateTime        @default(now())
  updated_at       DateTime
  campaign_logs    campaign_logs[]
  companies        companies       @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([scheduled_at])
  @@index([status])
  @@index([type])
}

model companies {
  id                      String                    @id
  name                    String
  created_at              DateTime                  @default(now())
  updated_at              DateTime
  ai_knowledge            ai_knowledge?
  appointments            appointments[]
  campaigns               campaigns[]
  customers               customers[]
  flows                   flows[]
  google_calendars        google_calendars?
  invites                 invites[]
  pipeline_stages         pipeline_stages[]
  service_additionals     service_additionals[]
  service_combos          service_combos[]
  service_zone_exceptions service_zone_exceptions[]
  service_zones           service_zones[]
  services                services[]
  tags                    tags[]
  users                   users[]
  whatsapp_instances      whatsapp_instances[]
  whatsapp_links          whatsapp_links[]
}

model conversation_examples {
  id              String        @id
  company_id      String
  conversation_id String        @unique
  notes           String?
  created_at      DateTime      @default(now())
  updated_at      DateTime
  conversations   conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([conversation_id])
}

model conversations {
  id                           String                 @id
  customer_id                  String                 @unique
  company_id                   String
  assigned_to_id               String?
  ai_enabled                   Boolean                @default(true)
  needs_help                   Boolean                @default(false)
  appointment_state            Json?
  created_at                   DateTime               @default(now())
  updated_at                   DateTime
  active_intent_script_id      String?
  intent_script_collected_data Json?
  conversation_examples        conversation_examples?
  users                        users?                 @relation(fields: [assigned_to_id], references: [id])
  customers                    customers              @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([ai_enabled])
  @@index([assigned_to_id])
  @@index([company_id])
  @@index([needs_help])
}

model customer_notes {
  id          String    @id
  customer_id String
  user_id     String
  note        String
  created_at  DateTime  @default(now())
  updated_at  DateTime
  customers   customers @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([customer_id])
  @@index([user_id])
}

model customers {
  id                String           @id
  company_id        String
  name              String
  phone             String
  email             String?
  tags              String[]         @default([])
  notes             String?
  profile_pic_url   String?
  is_group          Boolean          @default(false)
  pipeline_stage_id String?
  created_at        DateTime         @default(now())
  updated_at        DateTime
  address           String?
  neighborhood      String?
  zone_id           String?
  appointments      appointments[]
  conversations     conversations?
  customer_notes    customer_notes[]
  companies         companies        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  pipeline_stages   pipeline_stages? @relation(fields: [pipeline_stage_id], references: [id])
  service_zones     service_zones?   @relation(fields: [zone_id], references: [id])
  messages          messages[]

  @@unique([company_id, phone])
  @@index([company_id])
  @@index([email])
  @@index([is_group])
  @@index([phone])
  @@index([pipeline_stage_id])
  @@index([zone_id])
}

model flow_edges {
  id                                               String     @id
  flow_id                                          String
  source_node_id                                   String
  source_handle                                    String?
  target_node_id                                   String
  target_handle                                    String?
  created_at                                       DateTime   @default(now())
  flows                                            flows      @relation(fields: [flow_id], references: [id], onDelete: Cascade)
  flow_nodes_flow_edges_source_node_idToflow_nodes flow_nodes @relation("flow_edges_source_node_idToflow_nodes", fields: [source_node_id], references: [id], onDelete: Cascade)
  flow_nodes_flow_edges_target_node_idToflow_nodes flow_nodes @relation("flow_edges_target_node_idToflow_nodes", fields: [target_node_id], references: [id], onDelete: Cascade)

  @@index([flow_id])
  @@index([source_node_id])
  @@index([target_node_id])
}

model flow_executions {
  id              String              @id
  flow_id         String
  contact_phone   String
  current_node_id String?
  history         Json?               @default("[]")
  variables       Json?               @default("{}")
  status          FlowExecutionStatus @default(RUNNING)
  error           String?
  resumes_at      DateTime?
  started_at      DateTime            @default(now())
  completed_at    DateTime?
  updated_at      DateTime            @default(now())
  flow_nodes      flow_nodes?         @relation(fields: [current_node_id], references: [id])
  flows           flows               @relation(fields: [flow_id], references: [id], onDelete: Cascade)

  @@index([contact_phone])
  @@index([flow_id])
  @@index([resumes_at])
  @@index([status])
}

model flow_nodes {
  id                                               String            @id
  flow_id                                          String
  type                                             String
  data                                             Json
  position_x                                       Float
  position_y                                       Float
  created_at                                       DateTime          @default(now())
  updated_at                                       DateTime          @default(now())
  flow_edges_flow_edges_source_node_idToflow_nodes flow_edges[]      @relation("flow_edges_source_node_idToflow_nodes")
  flow_edges_flow_edges_target_node_idToflow_nodes flow_edges[]      @relation("flow_edges_target_node_idToflow_nodes")
  flow_executions                                  flow_executions[]
  flows                                            flows             @relation(fields: [flow_id], references: [id], onDelete: Cascade)

  @@index([flow_id])
}

model flows {
  id                   String            @id
  company_id           String
  name                 String
  description          String?
  trigger_type         String            @default("webhook")
  webhook_slug         String?           @unique
  last_webhook_payload Json?
  status               FlowStatus        @default(DRAFT)
  created_at           DateTime          @default(now())
  updated_at           DateTime          @default(now())
  flow_edges           flow_edges[]
  flow_executions      flow_executions[]
  flow_nodes           flow_nodes[]
  companies            companies         @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([status])
}

model google_calendars {
  id            String    @id
  company_id    String    @unique
  access_token  String
  refresh_token String
  token_expiry  DateTime
  calendar_id   String?
  email         String?
  created_at    DateTime  @default(now())
  updated_at    DateTime
  companies     companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model invites {
  id                                 String        @id
  company_id                         String
  email                              String
  name                               String
  cargo                              String?
  token                              String        @unique
  status                             InviteStatus  @default(PENDING)
  invited_by_id                      String
  user_id                            String?       @unique
  expires_at                         DateTime
  created_at                         DateTime      @default(now())
  updated_at                         DateTime
  companies                          companies     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  users_invites_invited_by_idTousers users         @relation("invites_invited_by_idTousers", fields: [invited_by_id], references: [id], onDelete: Cascade)
  users_invites_user_idTousers       users?        @relation("invites_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade)
  permissions                        permissions[]

  @@index([company_id])
  @@index([email])
  @@index([expires_at])
  @@index([status])
  @@index([token])
}

model link_clicks {
  id             String         @id
  link_id        String
  ip_address     String?
  user_agent     String?
  referer        String?
  country        String?
  region         String?
  city           String?
  latitude       Float?
  longitude      Float?
  device_type    String?
  browser        String?
  os             String?
  converted      Boolean        @default(false)
  converted_at   DateTime?
  customer_id    String?
  clicked_at     DateTime       @default(now())
  whatsapp_links whatsapp_links @relation(fields: [link_id], references: [id], onDelete: Cascade)

  @@index([clicked_at])
  @@index([converted])
  @@index([country])
  @@index([device_type])
  @@index([link_id])
}

model messages {
  id                   String             @id
  customer_id          String
  whatsapp_instance_id String
  direction            MessageDirection
  content              String
  timestamp            DateTime
  status               MessageStatus      @default(SENT)
  message_id           String?
  sender_type          SenderType?        @default(HUMAN)
  feedback             MessageFeedback?
  feedback_note        String?
  media_type           String?            @default("text")
  media_url            String?
  created_at           DateTime           @default(now())
  updated_at           DateTime
  customers            customers          @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  whatsapp_instances   whatsapp_instances @relation(fields: [whatsapp_instance_id], references: [id], onDelete: Cascade)

  @@unique([whatsapp_instance_id, message_id])
  @@index([customer_id])
  @@index([feedback])
  @@index([media_type])
  @@index([message_id])
  @@index([timestamp])
  @@index([whatsapp_instance_id])
}

model permissions {
  id         String         @id
  user_id    String?
  invite_id  String?
  page       PermissionPage
  can_view   Boolean        @default(true)
  can_edit   Boolean        @default(false)
  created_at DateTime       @default(now())
  updated_at DateTime
  invites    invites?       @relation(fields: [invite_id], references: [id], onDelete: Cascade)
  users      users?         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, page])
  @@index([invite_id])
  @@index([page])
  @@index([user_id])
}

model pipeline_stages {
  id          String      @id
  company_id  String
  name        String
  description String?
  color       String      @default("#8B5CF6")
  order       Int
  created_at  DateTime    @default(now())
  updated_at  DateTime
  customers   customers[]
  companies   companies   @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, name])
  @@index([company_id])
  @@index([order])
}

model service_additionals {
  id                    String    @id
  company_id            String
  name                  String
  description           String?
  price                 Decimal   @db.Decimal(10, 2)
  applies_to_categories String[]  @default([])
  is_active             Boolean   @default(true)
  order                 Int       @default(0)
  created_at            DateTime  @default(now())
  updated_at            DateTime
  companies             companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, name])
  @@index([company_id])
  @@index([is_active])
}

model service_combo_items {
  id             String         @id
  combo_id       String
  service_id     String
  quantity       Int            @default(1)
  notes          String?
  order          Int            @default(0)
  service_combos service_combos @relation(fields: [combo_id], references: [id], onDelete: Cascade)
  services       services       @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@index([combo_id])
  @@index([service_id])
}

model service_combos {
  id                  String                @id
  company_id          String
  name                String
  description         String?
  fixed_price         Decimal               @db.Decimal(10, 2)
  category            String?
  is_active           Boolean               @default(true)
  order               Int                   @default(0)
  created_at          DateTime              @default(now())
  updated_at          DateTime
  service_combo_items service_combo_items[]
  companies           companies             @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, name])
  @@index([category])
  @@index([company_id])
  @@index([is_active])
}

model service_pricing_tiers {
  id             String   @id
  service_id     String
  min_quantity   Int
  max_quantity   Int?
  price_per_unit Decimal  @db.Decimal(10, 2)
  order          Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime
  services       services @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@index([service_id])
}

model service_variable_options {
  id                String            @id
  variable_id       String
  name              String
  price_modifier    Decimal           @db.Decimal(10, 2)
  order             Int               @default(0)
  created_at        DateTime          @default(now())
  updated_at        DateTime
  service_variables service_variables @relation(fields: [variable_id], references: [id], onDelete: Cascade)

  @@index([variable_id])
}

model service_variables {
  id                       String                     @id
  service_id               String
  name                     String
  description              String?
  is_required              Boolean                    @default(true)
  order                    Int                        @default(0)
  created_at               DateTime                   @default(now())
  updated_at               DateTime
  service_variable_options service_variable_options[]
  services                 services                   @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@index([service_id])
}

model service_zone_exceptions {
  id             String    @id
  company_id     String
  zone_id        String
  service_id     String?
  category       String?
  min_quantity   Int?
  exception_type String
  custom_fee     Decimal?  @db.Decimal(10, 2)
  description    String?
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime
  companies      companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([company_id])
  @@index([service_id])
  @@index([zone_id])
}

model service_zones {
  id             String          @id
  company_id     String
  name           String
  description    String?
  pricing_type   ZonePricingType @default(FIXED)
  price_modifier Decimal         @default(0) @db.Decimal(10, 2)
  neighborhoods  String[]        @default([])
  is_default     Boolean         @default(false)
  requires_quote Boolean         @default(false)
  is_active      Boolean         @default(true)
  order          Int             @default(0)
  created_at     DateTime        @default(now())
  updated_at     DateTime
  customers      customers[]
  companies      companies       @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, name])
  @@index([company_id])
  @@index([is_active])
  @@index([is_default])
}

model services {
  id                    String                  @id
  company_id            String
  name                  String
  description           String?
  base_price            Decimal                 @db.Decimal(10, 2)
  type                  ServiceType             @default(SERVICE)
  category              String?
  is_active             Boolean                 @default(true)
  order                 Int                     @default(0)
  created_at            DateTime                @default(now())
  updated_at            DateTime
  duration              Int?                    @default(60)
  action_type           String?
  equipment_type        String?
  service_combo_items   service_combo_items[]
  service_pricing_tiers service_pricing_tiers[]
  service_variables     service_variables[]
  companies             companies               @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, name])
  @@index([company_id])
  @@index([is_active])
  @@index([type])
}

model tags {
  id         String    @id
  company_id String
  name       String
  color      String?   @default("#8B5CF6")
  created_at DateTime  @default(now())
  updated_at DateTime
  companies  companies @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, name])
  @@index([company_id])
}

model users {
  id                                   String           @id
  email                                String           @unique
  password_hash                        String?
  name                                 String
  role                                 UserRole         @default(USER)
  company_id                           String
  created_at                           DateTime         @default(now())
  updated_at                           DateTime
  cargo                                String?
  status                               String           @default("ACTIVE")
  conversations                        conversations[]
  customer_notes                       customer_notes[]
  invites_invites_invited_by_idTousers invites[]        @relation("invites_invited_by_idTousers")
  invites_invites_user_idTousers       invites?         @relation("invites_user_idTousers")
  permissions                          permissions[]
  companies                            companies        @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([email])
  @@index([status])
}

model whatsapp_instances {
  id            String         @id
  company_id    String
  instance_name String
  display_name  String?
  api_key       String?
  qr_code       String?
  status        WhatsAppStatus @default(DISCONNECTED)
  phone_number  String?
  connected_at  DateTime?
  created_at    DateTime       @default(now())
  updated_at    DateTime
  messages      messages[]
  companies     companies      @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@unique([company_id, instance_name])
  @@index([company_id])
  @@index([status])
}

model whatsapp_links {
  id           String        @id
  company_id   String
  name         String
  slug         String        @unique
  phone_number String
  message      String?
  auto_tag     String?
  is_active    Boolean       @default(true)
  created_at   DateTime      @default(now())
  updated_at   DateTime
  link_clicks  link_clicks[]
  companies    companies     @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([is_active])
  @@index([slug])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  VISIT
  INSTALLATION
  MAINTENANCE
  CONSULTATION
  OTHER
}

enum CampaignLogStatus {
  PENDING
  SENT
  FAILED
}

enum CampaignStatus {
  DRAFT
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum CampaignType {
  MANUAL
  SCHEDULED
}

enum FlowExecutionStatus {
  DELAYED
  RUNNING
  PAUSED
  WAITING_REPLY
  COMPLETED
  FAILED
}

enum FlowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageFeedback {
  GOOD
  BAD
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum PermissionPage {
  DASHBOARD
  CUSTOMERS
  CONVERSATIONS
  PIPELINE
  CALENDAR
  CAMPAIGNS
  WHATSAPP_LINKS
  AI_CONFIG
  WHATSAPP_CONFIG
}

enum SenderType {
  HUMAN
  AI
}

enum ServiceType {
  PRODUCT
  SERVICE
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
  USER
}

enum WhatsAppStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
}

enum ZonePricingType {
  FIXED
  PERCENTAGE
  CUSTOM
}
